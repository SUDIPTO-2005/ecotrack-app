# ============================================================
# EcoTrack Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Django
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (Neon/Supabase free tier compatible)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://ecotrack:password@localhost:5432/ecotrack_dev

# Redis (Upstash free tier compatible)
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Anthropic (Claude API) — server-side only, never expose to frontend
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_COACH_WEEKLY_CACHE_ENABLED=True
AI_COACH_RATE_LIMIT_PER_USER_PER_WEEK=1

# Email (Resend free tier — 3k emails/month)
RESEND_API_KEY=re_your_key_here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Offset Registry (Patch.io sandbox — informational only)
# REQUIRES_SANDBOX_KEY: Get a free sandbox key at https://www.patch.io
PATCH_API_KEY=
OFFSET_MARKETPLACE_MODE=informational  # Never change to 'transactional' without compliance review

# Government Data Sync
OWID_DATA_URL=https://raw.githubusercontent.com/owid/co2-data/master/owid-co2-data.csv
DATA_SYNC_SECRET=generate-a-random-secret-for-the-sync-webhook

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Sentry (free tier — 5k events/month)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Internal
INTERNAL_API_SECRET=generate-random-secret-for-internal-endpoints
